{
  "name": "mydocker-gui",
  "version": "1.0.0",
  "description": "Interfaz gráfica para gestionar Docker sin necesidad de memorizar comandos",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": ["docker", "electron", "gui", "desktop"],
  "author": "MyDocker GUI Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.mydocker.gui",
    "productName": "MyDocker GUI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ]
  }
}
